{
  "version": "0.2",
  "description": "SlopBench master slop list - cleaned to remove non-AI-specific terms",
  "categories": {

    "opener_slop": {
      "description": "Sycophantic or filler phrases used to open a response. These are AI-specific because a direct human would just answer.",
      "type": "behavioral",
      "detection": "string_match_response_start",
      "items": [
        "Certainly!",
        "Absolutely!",
        "Of course!",
        "Great question!",
        "Excellent question!",
        "That's a great point!",
        "Happy to help!",
        "I'd be happy to",
        "Sure thing!",
        "What a great question"
      ]
    },

    "validation_slop": {
      "description": "Phrases that validate the user sycophantically before or instead of answering. Very AI-specific.",
      "type": "behavioral",
      "detection": "string_match",
      "items": [
        "You're absolutely right",
        "You are absolutely right",
        "That's a really interesting perspective",
        "You raise a great point",
        "What a fascinating question",
        "I completely understand where you're coming from",
        "That's a very thoughtful question",
        "Great observation"
      ]
    },

    "reframe_slop": {
      "description": "Overused contrast/reframe sentence structures. AI loves this construction.",
      "type": "behavioral",
      "detection": "regex_pattern",
      "items": [
        "It's not X, it's Y",
        "This isn't about X, it's about Y",
        "Not just X, but Y",
        "Not just X, but also Y",
        "It's not just about X. It's about Y",
        "There's a kind of X that isn't Y. It doesn't come with"
      ],
      "notes": "Requires regex: 'not (just )?[\\w\\s]+, but (also )?[\\w\\s]+'"
    },

    "unnecessary_structure_slop": {
      "description": "Using bullet points, headers, or heavy formatting when a sentence or two would do. Scored by prompt type — if the answer should be simple prose, penalize structure.",
      "type": "structural",
      "detection": "llm_as_judge",
      "signals": [
        "bullet_points_for_simple_answer",
        "bold_headers_for_short_response",
        "numbered_list_for_single_concept",
        "tldr_section_unprompted",
        "summary_section_unprompted"
      ]
    },

    "em_dash_slop": {
      "description": "Overuse of em dashes where a comma or nothing would do. AI specifically overuses this punctuation.",
      "type": "structural",
      "detection": "regex_count",
      "notes": "Flag responses with 2+ em dashes (—) in a single response. Regex: /—/g"
    },

    "word_level_slop": {
      "description": "Individual words that are genuine AI fingerprints — not just business jargon or normal English words.",
      "type": "lexical",
      "detection": "string_match",
      "items": [
        "delve", "delved", "delving",
        "embark", "embarked",
        "unleash",
        "tapestry",
        "realm",
        "etched",
        "foray",
        "glean",
        "kaleidoscope",
        "holistic", "holistically",
        "transformative",
        "paradigm",
        "synergy", "synergistically",
        "groundbreaking",
        "cutting-edge",
        "game-changer",
        "pivotal",
        "paramount",
        "seamless",
        "vibrant",
        "nuanced",
        "multifaceted",
        "unparalleled",
        "invaluable",
        "leverage",
        "utilize",
