      ]
    },

    "phrase_level_slop": {
      "description": "Multi-word phrases that are genuine AI fingerprints.",
      "type": "lexical",
      "detection": "string_match",
      "items": [
        "smoking gun",
        "thundering herd",
        "a rich tapestry",
        "a testament to",
        "a treasure trove",
